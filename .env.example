# Copy to .env (and mirror non-public values into .dev.vars) for local dev.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
ALLOWED_GITHUB_LOGIN="your-github-login"
SESSION_SECRET="generate-with: openssl rand -hex 32"
PUBLIC_SITE_URL="http://localhost:4321"
# Classic PAT (repo + workflow) — admin Publish button triggers the deploy workflow.
GITHUB_DISPATCH_TOKEN=""
# Read-only token (public_repo / read:user) — build-time pinned repos + contributions on /about.
GITHUB_READ_TOKEN=""
# Admin image uploads — UploadThing (preferred). Get from uploadthing.com dashboard.
UPLOADTHING_TOKEN=""
# Optional R2 fallback (only used if UPLOADTHING_TOKEN is unset)
R2_PUBLIC_URL=""
