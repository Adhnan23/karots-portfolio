---
import { NAV_LINKS, SITE } from "@/lib/nav";
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border">
  <div class="container-page flex flex-col gap-6 py-10 md:flex-row md:items-center md:justify-between">
    <div>
      <div class="font-mono text-sm text-fg">
        <span class="text-accent">~/</span>{SITE.handle}
      </div>
      <p class="mt-1 text-sm text-fg-subtle">
        {SITE.role} · Puttalam, Sri Lanka
      </p>
    </div>

    <ul class="flex flex-wrap gap-x-5 gap-y-2">
      {
        NAV_LINKS.map((l) => (
          <li>
            <a href={l.href} class="font-mono text-sm text-fg-muted hover:text-accent">
              /{l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex gap-4 font-mono text-sm">
      <a href={SITE.github} target="_blank" rel="noopener" class="text-fg-muted hover:text-accent">github</a>
      <a href={`mailto:${SITE.email}`} class="text-fg-muted hover:text-accent">email</a>
    </div>
  </div>
  <div class="container-page pb-8 text-xs text-fg-subtle">
    <span class="text-accent">$</span> echo "© {year} {SITE.name}. Built with Astro + Cloudflare."
  </div>
</footer>
