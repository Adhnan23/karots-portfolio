---
import { NAV_LINKS, SITE } from "@/lib/nav";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md"
>
  <nav class="container-page flex h-16 items-center justify-between">
    <a href="/" class="group flex items-center gap-2 font-mono font-semibold">
      <span class="text-accent">~/</span>
      <span class="text-fg">{SITE.handle}</span>
      <span class="text-accent animate-pulse">_</span>
    </a>

    <ul class="hidden items-center gap-1 md:flex">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
              class:list={[
                "rounded px-3 py-2 font-mono text-sm transition-colors",
                isActive(link.href)
                  ? "text-accent"
                  : "text-fg-muted hover:text-fg",
              ]}
            >
              <span class="text-fg-subtle">/</span>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <a
        href={SITE.github}
        target="_blank"
        rel="noopener"
        class="btn btn-ghost hidden sm:inline-flex"
        aria-label="GitHub"
      >
        github
      </a>
      <button
        id="menu-toggle"
        class="md:hidden text-fg-muted hover:text-fg"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <ul class="container-page flex flex-col py-2">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
              class:list={[
                "block px-2 py-2.5 font-mono text-sm",
                isActive(link.href) ? "text-accent" : "text-fg-muted",
              ]}
            >
              /{link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(open === false));
  });
</script>
