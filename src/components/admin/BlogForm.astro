---
import ImageField from "@/components/admin/ImageField.astro";
import type { BlogPost } from "@/db/schema";

interface Props {
  post?: BlogPost;
}
const { post: p } = Astro.props;
---

<form method="POST" action="/api/admin/blog" class="max-w-3xl space-y-5">
  {p && <input type="hidden" name="id" value={p.id} />}

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label class="field-label" for="title">Title</label>
      <input class="field" id="title" name="title" value={p?.title ?? ""} required />
    </div>
    <div>
      <label class="field-label" for="slug">Slug</label>
      <input class="field" id="slug" name="slug" value={p?.slug ?? ""} placeholder="auto from title" />
    </div>
  </div>

  <div>
    <label class="field-label" for="excerpt">Excerpt</label>
    <textarea class="field" id="excerpt" name="excerpt" rows="2">{p?.excerpt ?? ""}</textarea>
  </div>

  <div>
    <span class="field-label">Body</span>
    <div id="editor" class="mt-1"></div>
    <textarea id="body" name="body" class="hidden">{p?.body ?? ""}</textarea>
    <p class="field-hint editor-status"></p>
  </div>

  <div>
    <label class="field-label" for="tags">Tags (comma-separated)</label>
    <input class="field" id="tags" name="tags" value={p?.tags.join(", ") ?? ""} />
  </div>

  <ImageField name="coverImageUrl" label="Cover image" value={p?.coverImageUrl ?? ""} />

  <div class="flex items-center justify-between border-t border-border pt-5">
    <label class="flex items-center gap-2 font-mono text-sm text-fg-muted">
      <input type="checkbox" name="published" checked={p?.published} /> published
    </label>
    <div class="flex gap-3">
      <a href="/admin/blog" class="btn btn-ghost">cancel</a>
      <button class="btn btn-primary" type="submit">{p ? "save changes" : "create post"}</button>
    </div>
  </div>
</form>

<script>
  import Editor from "@toast-ui/editor";
  import "@toast-ui/editor/dist/toastui-editor.css";
  import "@toast-ui/editor/dist/theme/toastui-editor-dark.css";

  const el = document.getElementById("editor");
  const bodyField = document.getElementById("body") as HTMLTextAreaElement | null;
  const statusEl = document.querySelector<HTMLElement>(".editor-status");
  const form = bodyField?.closest("form");

  function setStatus(msg: string, color: string) {
    if (statusEl) {
      statusEl.textContent = msg;
      statusEl.style.color = color;
    }
  }

  if (el && bodyField && form) {
    const editor = new Editor({
      el,
      height: "560px",
      initialEditType: "wysiwyg",
      previewStyle: "vertical",
      theme: "dark",
      usageStatistics: false,
      initialValue: bodyField.value,
      hooks: {
        // Upload a pasted/inserted image to /api/admin/upload, then drop the
        // returned URL in at the cursor as ![alt](url).
        addImageBlobHook: async (blob, callback) => {
          const file = blob as File;
          setStatus("uploading image…", "var(--color-fg-muted)");
          const fd = new FormData();
          fd.append("file", file);
          try {
            const res = await fetch("/api/admin/upload", { method: "POST", body: fd });
            const data = await res.json();
            if (res.ok && data.url) {
              callback(data.url, file.name ?? "image");
              setStatus("✓ image inserted", "var(--color-online)");
            } else {
              setStatus(data.error ?? "image upload failed", "var(--color-danger)");
            }
          } catch {
            setStatus("network error", "var(--color-danger)");
          }
        },
      },
    });

    // Sync the editor's markdown into the hidden field right before submit.
    form.addEventListener("submit", () => {
      bodyField.value = editor.getMarkdown();
    });
  }
</script>
