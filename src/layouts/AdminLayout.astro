---
import "@/styles/global.css";
import { ADMIN_NAV } from "@/lib/admin-nav";

interface Props {
  title: string;
}
const { title } = Astro.props;
const session = Astro.locals.session;
const path = Astro.url.pathname;
const active = (href: string) => (href === "/admin" ? path === "/admin" : path.startsWith(href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title} · admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700&family=IBM+Plex+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="hidden w-60 shrink-0 flex-col border-r border-border bg-bg-soft md:flex">
        <div class="flex h-16 items-center gap-2 border-b border-border px-5 font-mono font-semibold">
          <span class="text-accent">~/</span>admin
        </div>
        <nav class="flex flex-1 flex-col gap-0.5 p-3">
          {
            ADMIN_NAV.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "flex items-center gap-3 rounded-md px-3 py-2 font-mono text-sm transition-colors",
                  active(item.href)
                    ? "bg-surface text-accent"
                    : "text-fg-muted hover:bg-surface hover:text-fg",
                ]}
              >
                <span class="w-4 text-center opacity-70">{item.icon}</span>
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="border-t border-border p-3">
          <a href="/" target="_blank" class="block px-3 py-1.5 font-mono text-xs text-fg-subtle hover:text-accent">
            ↗ view live site
          </a>
        </div>
      </aside>

      <!-- Main -->
      <div class="flex min-w-0 flex-1 flex-col">
        <header class="flex h-16 items-center justify-between border-b border-border px-5">
          <h1 class="font-display text-lg font-semibold">{title}</h1>
          <div class="flex items-center gap-3">
            {
              session?.avatarUrl && (
                <img src={session.avatarUrl} alt="" class="h-7 w-7 rounded-full border border-border" />
              )
            }
            <span class="hidden font-mono text-xs text-fg-muted sm:inline">{session?.login}</span>
            <form method="POST" action="/api/auth/logout">
              <button class="btn btn-ghost px-3 py-1.5 text-xs">logout</button>
            </form>
          </div>
        </header>

        <!-- Mobile nav -->
        <nav class="flex gap-1 overflow-x-auto border-b border-border px-3 py-2 md:hidden">
          {
            ADMIN_NAV.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "whitespace-nowrap rounded px-2.5 py-1.5 font-mono text-xs",
                  active(item.href) ? "bg-surface text-accent" : "text-fg-muted",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>

        <main class="flex-1 p-5 md:p-8">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
