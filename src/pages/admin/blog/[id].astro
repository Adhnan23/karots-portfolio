---
import AdminLayout from "@/layouts/AdminLayout.astro";
import Flash from "@/components/admin/Flash.astro";
import BlogForm from "@/components/admin/BlogForm.astro";
import { getDb } from "@/db";
import { blogPosts } from "@/db/schema";
import { eq } from "drizzle-orm";
import { envFromLocals } from "@/lib/env";

export const prerender = false;

const id = Number(Astro.params.id);
if (!Number.isInteger(id)) return Astro.redirect("/admin/blog");

const db = getDb(envFromLocals(Astro.locals));
const [post] = await db.select().from(blogPosts).where(eq(blogPosts.id, id)).limit(1);
if (!post) return Astro.redirect("/admin/blog");
---

<AdminLayout title={`Edit · ${post.title}`}>
  <Flash />
  <div class="mb-5">
    <a href="/admin/blog" class="font-mono text-sm text-fg-muted hover:text-accent">← all posts</a>
  </div>
  <BlogForm post={post} />
</AdminLayout>
