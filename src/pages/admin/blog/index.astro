---
import AdminLayout from "@/layouts/AdminLayout.astro";
import Flash from "@/components/admin/Flash.astro";
import { getBlogPosts } from "@/lib/content";
import { envFromLocals } from "@/lib/env";

export const prerender = false;

const posts = await getBlogPosts({ includeUnpublished: true }, envFromLocals(Astro.locals));
---

<AdminLayout title="Blog">
  <Flash />
  <div class="mb-5 flex items-center justify-between">
    <p class="font-mono text-sm text-fg-muted">{posts.length} posts</p>
    <a href="/admin/blog/new" class="btn btn-primary">+ new post</a>
  </div>

  <div class="card overflow-x-auto">
    <table class="admin-table">
      <thead>
        <tr><th>Title</th><th>Status</th><th>Published</th><th></th></tr>
      </thead>
      <tbody>
        {
          posts.length === 0 && (
            <tr><td colspan="4" class="text-fg-subtle">No posts yet.</td></tr>
          )
        }
        {
          posts.map((p) => (
            <tr>
              <td><a href={`/admin/blog/${p.id}`} class="font-medium text-fg hover:text-accent">{p.title}</a></td>
              <td>
                {p.published
                  ? <span class="status status-live"><span class="status-dot"></span>live</span>
                  : <span class="tag">draft</span>}
              </td>
              <td class="font-mono text-xs text-fg-subtle">{p.publishedAt?.toISOString().slice(0, 10) ?? "—"}</td>
              <td class="text-right">
                <div class="flex justify-end gap-3 font-mono text-xs">
                  <a href={`/admin/blog/${p.id}`} class="text-fg-muted hover:text-accent">edit</a>
                  <form method="POST" action="/api/admin/blog" onsubmit="return confirm('Delete this post?')">
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="id" value={p.id} />
                    <button class="text-fg-muted hover:text-danger" type="submit">delete</button>
                  </form>
                </div>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</AdminLayout>
