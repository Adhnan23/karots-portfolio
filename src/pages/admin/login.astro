---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { resolveEnv, envFromLocals } from "@/lib/env";

export const prerender = false;

// Already signed in? Go to dashboard.
if (Astro.locals.session) return Astro.redirect("/admin");

const env = resolveEnv(envFromLocals(Astro.locals));
const configured = !!env.GITHUB_CLIENT_ID && !!env.GITHUB_CLIENT_SECRET;

const errors: Record<string, string> = {
  state: "Login session expired or was tampered with. Try again.",
  forbidden: "That GitHub account isn't authorized for this admin.",
  oauth: "GitHub rejected the sign-in. Try again.",
  unknown: "Something went wrong signing in. Try again.",
};
const error = Astro.url.searchParams.get("error");
const errorMsg = error ? errors[error] ?? errors.unknown : null;
---

<BaseLayout title="Admin sign in" noindex={true}>
  <section class="container-page flex min-h-[70vh] items-center justify-center py-20">
    <div class="card w-full max-w-sm p-8">
      <p class="mono-label">// restricted</p>
      <h1 class="mt-3 font-display text-2xl font-bold">Admin access</h1>
      <p class="mt-2 text-sm text-fg-muted">
        Sign in with the owner's GitHub account to manage content.
      </p>

      {
        errorMsg && (
          <p class="mt-4 rounded-md border border-danger/40 bg-danger/10 px-3 py-2 font-mono text-xs" style="color:var(--color-danger)">
            {errorMsg}
          </p>
        )
      }

      {
        configured ? (
          <a href="/api/auth/github" class="btn btn-primary mt-6 w-full justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            Sign in with GitHub
          </a>
        ) : (
          <div class="mt-6 rounded-md border border-border bg-bg-soft p-4 font-mono text-xs text-fg-muted">
            GitHub OAuth isn't configured yet. Set <span class="text-accent">GITHUB_CLIENT_ID</span> and
            <span class="text-accent">GITHUB_CLIENT_SECRET</span> in your environment.
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
