---
import AdminLayout from "@/layouts/AdminLayout.astro";
import Flash from "@/components/admin/Flash.astro";
import { getDb } from "@/db";
import { contactMessages } from "@/db/schema";
import { desc } from "drizzle-orm";
import { envFromLocals } from "@/lib/env";

export const prerender = false;
const db = getDb(envFromLocals(Astro.locals));
const messages = await db.select().from(contactMessages).orderBy(desc(contactMessages.createdAt));
const unread = messages.filter((m) => !m.read).length;
---

<AdminLayout title="Messages">
  <Flash />
  <p class="mb-5 font-mono text-sm text-fg-muted">{messages.length} total · {unread} unread</p>

  {
    messages.length === 0 ? (
      <p class="font-mono text-sm text-fg-subtle"><span class="text-accent">$</span> inbox empty.</p>
    ) : (
      <div class="space-y-3">
        {messages.map((m) => (
          <div class:list={["card p-5", !m.read && "border-l-2 border-l-accent"]}>
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="font-medium text-fg">
                  {m.name}
                  {!m.read && <span class="ml-2 align-middle tag" style="color:var(--color-accent)">new</span>}
                </p>
                <a href={`mailto:${m.email}`} class="font-mono text-xs text-accent">{m.email}</a>
              </div>
              <span class="font-mono text-xs text-fg-subtle">{m.createdAt.toISOString().slice(0, 16).replace("T", " ")}</span>
            </div>
            <p class="mt-3 whitespace-pre-wrap text-sm text-fg-muted">{m.message}</p>
            <div class="mt-4 flex gap-3 font-mono text-xs">
              <form method="POST" action="/api/admin/messages">
                <input type="hidden" name="id" value={m.id} />
                <input type="hidden" name="_action" value="toggle-read" />
                <button class="text-fg-muted hover:text-accent" type="submit">{m.read ? "mark unread" : "mark read"}</button>
              </form>
              <form method="POST" action="/api/admin/messages" onsubmit="return confirm('Delete this message?')">
                <input type="hidden" name="id" value={m.id} />
                <input type="hidden" name="_action" value="delete" />
                <button class="text-fg-muted hover:text-danger" type="submit">delete</button>
              </form>
            </div>
          </div>
        ))}
      </div>
    )
  }
</AdminLayout>
