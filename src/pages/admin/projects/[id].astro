---
import AdminLayout from "@/layouts/AdminLayout.astro";
import Flash from "@/components/admin/Flash.astro";
import ProjectForm from "@/components/admin/ProjectForm.astro";
import { getDb } from "@/db";
import { projects } from "@/db/schema";
import { eq } from "drizzle-orm";
import { envFromLocals } from "@/lib/env";

export const prerender = false;

const id = Number(Astro.params.id);
if (!Number.isInteger(id)) return Astro.redirect("/admin/projects");

const db = getDb(envFromLocals(Astro.locals));
const [project] = await db.select().from(projects).where(eq(projects.id, id)).limit(1);
if (!project) return Astro.redirect("/admin/projects");
---

<AdminLayout title={`Edit · ${project.title}`}>
  <Flash />
  <div class="mb-5 flex items-center justify-between">
    <a href="/admin/projects" class="font-mono text-sm text-fg-muted hover:text-accent">← all projects</a>
    <a href={`/projects/${project.slug}`} target="_blank" class="font-mono text-sm text-fg-muted hover:text-accent">↗ view live</a>
  </div>
  <ProjectForm project={project} />
</AdminLayout>
