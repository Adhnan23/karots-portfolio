---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getProjects, getProjectBySlug } from "@/lib/content";
import { renderMarkdown } from "@/lib/markdown";
import { projectLinks, sourceLabel, categoryLabel, isLive } from "@/lib/project-display";
import { SITE } from "@/lib/nav";

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = await getProjectBySlug(slug!);
if (!project) return Astro.redirect("/404");

// Case-study sections (all optional). If none are filled, fall back to the
// freeform overview so older projects still render a body.
const hasCaseStudy = Boolean(project.problem || project.approach || project.outcome);
const caseStudy = hasCaseStudy
  ? await Promise.all(
      (
        [
          { label: "problem", md: project.problem },
          { label: "approach", md: project.approach },
          { label: "outcome", md: project.outcome },
        ] as const
      )
        .filter((s) => s.md.trim())
        .map(async (s) => ({ label: s.label, html: await renderMarkdown(s.md) }))
    )
  : [];
const overviewHtml = project.description.trim() ? await renderMarkdown(project.description) : "";
const links = projectLinks(project);
const live = isLive(project);
const src = sourceLabel(project);

const origin = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(`/projects/${project.slug}/`, origin).href;

// SoftwareSourceCode for repo projects, otherwise generic CreativeWork.
const projectLd = {
  "@context": "https://schema.org",
  "@type": project.repoUrl ? "SoftwareSourceCode" : "CreativeWork",
  name: project.title,
  description: project.summary,
  url: canonical,
  author: { "@type": "Person", name: SITE.name, url: origin.href },
  keywords: project.tech.join(", "),
  ...(project.repoUrl ? { codeRepository: project.repoUrl } : {}),
  ...(project.liveUrl ? { sameAs: project.liveUrl } : {}),
  ...(project.coverImageUrl ? { image: new URL(project.coverImageUrl, origin).href } : {}),
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Projects", item: new URL("/projects/", origin).href },
    { "@type": "ListItem", position: 2, name: project.title, item: canonical },
  ],
};
---

<BaseLayout
  title={`${project.title} — Project`}
  description={project.summary}
  image={project.coverImageUrl ?? undefined}
  jsonLd={[projectLd, breadcrumbLd]}
>
  <article class="container-page py-12 md:py-16">
    <a href="/projects" class="font-mono text-sm text-fg-muted hover:text-accent">← all projects</a>

    <header class="mt-6 border-b border-border pb-8">
      <div class="flex flex-wrap items-center gap-3">
        <span class="tag">{categoryLabel(project.category)}</span>
        {live && <span class="status status-live"><span class="status-dot"></span>live</span>}
        <span class="font-mono text-xs text-fg-subtle">{project.dateRange}</span>
      </div>
      <h1 class="mt-4 font-display text-4xl font-bold md:text-5xl">{project.title}</h1>
      <p class="mt-4 max-w-2xl text-lg text-fg-muted">{project.summary}</p>
    </header>

    {
      project.metrics.length > 0 && (
        <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {project.metrics.map((m) => (
            <div class="card p-4">
              <div class="font-display text-2xl font-bold text-accent md:text-3xl">{m.value}</div>
              <div class="mt-1 font-mono text-[0.68rem] uppercase tracking-wide text-fg-subtle">{m.label}</div>
            </div>
          ))}
        </div>
      )
    }

    <div class="mt-10 grid gap-12 md:grid-cols-[1fr_240px]">
      <!-- Body -->
      <div class="order-2 md:order-1">
        {
          project.architectureImageUrl && (
            <figure class="mb-10">
              <img
                src={project.architectureImageUrl}
                alt={`${project.title} architecture`}
                loading="lazy"
                class="card mx-auto h-auto w-full"
              />
              <figcaption class="mt-2 text-center font-mono text-xs text-fg-subtle">
                // architecture
              </figcaption>
            </figure>
          )
        }
        {
          hasCaseStudy ? (
            <div class="flex flex-col gap-10">
              {caseStudy.map((s) => (
                <section>
                  <h2 class="mono-label mb-3">// {s.label}</h2>
                  <div class="prose-tech" set:html={s.html} />
                </section>
              ))}
            </div>
          ) : (
            <div class="prose-tech" set:html={overviewHtml} />
          )
        }
      </div>

      <!-- Meta sidebar -->
      <aside class="order-1 flex flex-col gap-6 md:order-2">
        {
          links.length > 0 && (
            <div>
              <h3 class="mono-label mb-2">links</h3>
              <div class="flex flex-col gap-2">
                {links.map((l) => (
                  <a href={l.href} target="_blank" rel="noopener" class="btn btn-ghost justify-start">
                    {l.kind === "live" ? "↗ visit live" : "<> view source"}
                  </a>
                ))}
              </div>
            </div>
          )
        }
        {
          src && links.length === 0 && (
            <div>
              <h3 class="mono-label mb-2">availability</h3>
              <p class="text-sm text-fg-muted">{src}</p>
            </div>
          )
        }
        {
          project.role && (
            <div>
              <h3 class="mono-label mb-2">role</h3>
              <p class="text-sm text-fg-muted">{project.role}</p>
            </div>
          )
        }
        <div>
          <h3 class="mono-label mb-2">stack</h3>
          <ul class="flex flex-wrap gap-1.5">
            {project.tech.map((t) => <li class="tag">{t}</li>)}
          </ul>
        </div>
      </aside>
    </div>

    {
      project.gallery.length > 0 && (
        <div class="mt-12 grid gap-4 sm:grid-cols-2">
          {project.gallery.map((g) => (
            <img src={g.url} alt={g.alt ?? project.title} loading="lazy" class="card w-full" />
          ))}
        </div>
      )
    }
  </article>
</BaseLayout>
